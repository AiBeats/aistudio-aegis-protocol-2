# ABV Sovereign Stack — Environment Configuration
# Copy this file to .env and fill in actual values.

# ---- Squad Mesh FOB MAC Addresses ----
FOB_MAC_1=AA:BB:CC:DD:EE:01
FOB_MAC_2=AA:BB:CC:DD:EE:02
FOB_MAC_3=AA:BB:CC:DD:EE:03
FOB_MAC_4=AA:BB:CC:DD:EE:04
FOB_MAC_5=AA:BB:CC:DD:EE:05

# ---- TPM / Encryption ----
TPM_SECRET_KEY=your-tpm-secret-key-here
CRYSTAL_ENCRYPTION_KEY=your-crystal-encryption-key-here

# ---- SOS Relay ----
SOS_RELAY_URL=http://localhost:9000/sos
SOS_HMAC_SECRET=your-sos-hmac-secret-here

# ---- Transport / GPS ----
TRANSPORT_GPS_API_KEY=your-gps-api-key-here

# ---- VPN / Mesh ----
VPN_MESH_ENDPOINT=http://localhost:51820/health

# ---- Thermal Governor ----
CPU_TEMP_CRITICAL=95
GPU_TEMP_CRITICAL=90
THERMAL_POLL_INTERVAL=2.0

# ---- Build Mode ----
ABV_BUILD_MODE=PUBLIC
ABV_LOG_LEVEL=INFO

# ---- Network Fingerprinting ----
ABV_HOME_SSIDS=HomeWiFi,HomeLAN
ABV_OFFICE_SSIDS=CorpNet

# ---- Feature Flags (1 = enabled, 0 = disabled) ----
ABV_FLAG_THERMAL_GOVERNOR=1
ABV_FLAG_SOS_LISTENER=1
ABV_FLAG_PROTOCOL_A3=1
ABV_FLAG_CRYSTAL_VAULT=1
ABV_FLAG_TRANSPORT_MODE=0
ABV_FLAG_SQUAD_MESH=0
ABV_FLAG_BIOMETRIC_DURESS=0
ABV_FLAG_SCORCHED_EARTH=0
